{
  "name": "telegram-personal-assistant",
  "version": "1.0.0",
  "description": "Telegram personal assistant bot with reminders and natural language parsing.",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0",
    "dotenv": "^16.4.5",
    "luxon": "^3.5.0",
    "node-cron": "^3.0.3",
    "openai": "^4.73.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.14.10",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
